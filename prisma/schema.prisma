// Prisma schema for Job Aggregator
// Mirrors docs/04-database-schema.md. Keep the two in sync.
// FTS GIN index on (title || company || description) is added via a manual
// migration (Prisma can't express tsvector GIN yet) — see prisma/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Source {
  greenhouse
  lever
  ashby
  remoteok
  linkedin
  threads
}

enum RemoteType {
  remote
  hybrid
  onsite
  unknown
}

enum Tier {
  intern
  entry
  mid
  senior
  staff
  principal
  unknown
}

enum RunStatus {
  running
  success
  partial
  failed
}

enum RunMode {
  full
  incremental
}

model Job {
  id               String     @id @default(uuid()) @db.Uuid
  source           Source
  externalId       String     @map("external_id")
  title            String
  company          String
  companyDomain    String?    @map("company_domain")
  location         String
  remoteType       RemoteType @default(unknown) @map("remote_type")
  department       String?
  description      String
  applyUrl         String     @map("apply_url")
  postedAt         DateTime   @map("posted_at") @db.Timestamptz(6)
  expiresAt        DateTime?  @map("expires_at") @db.Timestamptz(6)
  firstSeenAt      DateTime   @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt       DateTime   @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  updatedSourceAt  DateTime?  @map("updated_source_at") @db.Timestamptz(6)
  salaryMin        Int?       @map("salary_min")
  salaryMax        Int?       @map("salary_max")
  salaryCurrency   String?    @map("salary_currency")
  tier             Tier       @default(unknown)
  techStack        String[]   @map("tech_stack")
  raw              Json
  isExpired        Boolean    @default(false) @map("is_expired")

  @@unique([source, externalId], name: "source_external_id")
  @@index([source, postedAt(sort: Desc)])
  @@index([isExpired, postedAt(sort: Desc)])
  @@index([techStack], type: Gin)
  @@index([lastSeenAt])
  @@map("jobs")
}

model ScraperRun {
  id            String    @id @default(uuid()) @db.Uuid
  source        Source
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)
  status        RunStatus @default(running)
  mode          RunMode
  jobsSeen      Int       @default(0) @map("jobs_seen")
  jobsInserted  Int       @default(0) @map("jobs_inserted")
  jobsUpdated   Int       @default(0) @map("jobs_updated")
  jobsExpired   Int       @default(0) @map("jobs_expired")
  errorMessage  String?   @map("error_message")
  metadata      Json      @default("{}")

  @@index([source, startedAt(sort: Desc)])
  @@map("scraper_runs")
}
