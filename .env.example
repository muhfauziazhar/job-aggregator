# Job Aggregator — environment variables
# Copy to .env.local (app) / export in shell (scrapers). Never commit real values.

# --- Database (required) ---
# Postgres connection string. Local Docker example below; prod uses Neon/Vercel Postgres.
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:54321/jobagg?schema=public"

# --- LinkedIn scraper (M2, optional until then) ---
# Use a DISPOSABLE account. See docs/adr/0001-linkedin-scraping-strategy.md
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""

# Optional residential proxy for LinkedIn rotation (format: http://user:pass@host:port)
RESIDENTIAL_PROXY_URL=""

# --- Observability (optional) ---
SENTRY_DSN=""

# --- App ---
# Public base URL used for canonical/OG tags. No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
