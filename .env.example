# Job Aggregator — environment variables
# Copy to .env.local (app) / export in shell (scrapers). Never commit real values.
#
# The app is a static site (no database). Scraped jobs are read from
# public/data/jobs.json at build/runtime, so the frontend needs no env vars.
# The variables below are only used by the Python scrapers.

# --- LinkedIn scraper (optional) ---
# Use a DISPOSABLE account. See docs/adr/0001-linkedin-scraping-strategy.md
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""

# Optional residential proxy for LinkedIn rotation (format: http://user:pass@host:port)
RESIDENTIAL_PROXY_URL=""

# --- Observability (optional) ---
SENTRY_DSN=""
